# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server only — never expose to the client

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM=".ppl Solutions <hello@pplsolutionsinc.com>"   # must be a verified domain/sender
CONTACT_NOTIFY_EMAIL=               # internal address that receives form notifications

# Site
NEXT_PUBLIC_SITE_URL=https://www.pplsolutionsinc.com

# Staging only — set these to password-protect a preview deployment and mark it
# noindex. Leave BOTH unset in production so the site is publicly reachable.
STAGING_USER=ppl
STAGING_PASSWORD=
